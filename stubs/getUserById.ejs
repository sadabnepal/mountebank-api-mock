{
    "predicates": [
        {
            "equals": { 
                "method": "GET" 
            }
        },
        {
            "matches": { 
                "path": "^/api/users/[0-9]+$" 
            }
        }
    ],
    "responses": [
        {
            "inject": "<%- stringify(filename, 'helper/fetchByPathParam.js') %>"
        }
    ]
}